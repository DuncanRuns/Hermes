{
  "required": true,
  "package": "me.duncanruns.hermes.mixin",
  "compatibilityLevel": "JAVA_8",
  "mixins": [
    "ghost.MinecraftServerMixin",
    //? if <=1.12.2
    //"playlog.CommandRegistryMixin",
    //? if >=1.13
    "playlog.CommandManagerMixin",
    "playlog.MinecraftServerMixin",
    "playlog.PlayerAdvancementsMixin",
    //? if <=1.12.2
    //"playlog.PlayerManagerAccessor",
    "playlog.PlayerManagerMixin",
    "playlog.ServerPlayerStatsMixin",
    "playlog.ServerWorldMixin",
    "worldpath.MinecraftServerMixin"
  ],
  "injectors": {
    "defaultRequire": 1
  },
  "overwrites": {
    "requireAnnotations": true
  },
  "client": [
    "client.MinecraftMixin",
    "client.instancestate.MinecraftMixin",
    "client.playlog.MinecraftMixin",
    "client.playlog.enteredseed.CreateWorldScreenMixin",
    "client.worldlog.MinecraftMixin"
  ],
  "server": [
    "server.MinecraftServerMixin",
    "server.instancestate.MinecraftServerMixin"
  ],
  "plugin": "me.duncanruns.hermes.HermesMixinPlugin"
}