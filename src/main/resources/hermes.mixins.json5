{
  "required": true,
  "package": "me.duncanruns.hermes.mixin",
  "compatibilityLevel": "JAVA_25",
  "mixins": [
    "ghost.MinecraftServerMixin",
    "playlog.MinecraftServerMixin",
    "worldpath.MinecraftServerMixin",
    "playlog.CommandsMixin",
    "playlog.PlayerAdvancementsMixin",
    "playlog.PlayerListMixin",
    "playlog.ServerLevelMixin",
    "playlog.ServerStatsCounterMixin"
  ],
  "injectors": {
    "defaultRequire": 1
  },
  "overwrites": {
    "requireAnnotations": true
  },
  "client": [
    "client.MinecraftMixin",
    "instancestate.client.MinecraftMixin",
    "playlog.client.MinecraftMixin",
    "playlog.client.enteredseed.CreateWorldScreenMixin",
    "worldlog.client.MinecraftMixin"
  ],
  "server": [
    "instancestate.server.MinecraftServerMixin",
    "server.MinecraftServerMixin"
  ],
  "plugin": "me.duncanruns.hermes.HermesMixinPlugin"
}